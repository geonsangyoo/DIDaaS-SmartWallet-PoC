# ThirdWeb client ID (from https://thirdweb.com/dashboard)
NEXT_PUBLIC_TEMPLATE_CLIENT_ID=

# Google OAuth client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Backend URL for JWT auth (default: http://localhost:3001)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ── Multi-Sig Safe owner EOA addresses (PUBLIC — not secrets) ─────────────────
# Each person logs in once with their Google account on the /multisig page.
# Copy their displayed ThirdWeb wallet address here, then restart the dev server.
# The Safe is deployed automatically (counterfactual) on the first expense proposal.
#
# 社員 (Employee) — proposes expense transactions
NEXT_PUBLIC_EMPLOYEE_ADDRESS=
# 上長 (Manager / admin1) — first approver
NEXT_PUBLIC_ADMIN1_ADDRESS=
# 経理担当 (Accounting / admin2) — second approver, triggers execution
NEXT_PUBLIC_ADMIN2_ADDRESS=

# ── Safe Transaction Service API key (required for propose/confirm) ───────────
# safe-transaction-sepolia.safe.global now redirects POST requests to
# api.safe.global which requires authentication → 404 without a key.
# Get a free key at https://developer.safe.global (free tier, testnet OK).
NEXT_PUBLIC_SAFE_API_KEY=

# ── Batch Transaction Verification (/batch) ──────────────────────────────────
# Two ETH recipients — both transfers are packed into a single ERC-4337 UserOperation.
NEXT_PUBLIC_BATCH_RECIPIENT_1=
NEXT_PUBLIC_BATCH_RECIPIENT_2=
# ETH amounts to send (default: 0.001 each)
NEXT_PUBLIC_BATCH_AMOUNT_1=0.001
NEXT_PUBLIC_BATCH_AMOUNT_2=0.001

# ── Safe address (optional but recommended) ───────────────────────────────────
# Recommended: create the Safe at https://app.safe.global (Sepolia, same 3 owners,
# threshold 3) and paste the address here. This skips the on-page deploy step and
# avoids the Safe TX Service v2 "404 undeployed Safe" issue.
# If left empty the app computes a counterfactual address and shows a Deploy button.
NEXT_PUBLIC_SAFE_ADDRESS=
